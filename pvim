#!/usr/bin/env sh

# Get the path to pvim
export PVIM="$(dirname "$(readlink -e -- "$0")")"

downloadAppimage() {
  if [ "$imageLocation" = "$PVIM/nvim.appimage" ]; then
    appimageNeeded=false
    if [ -z "$nightly" ]; then
      getNightlyStatus
    fi
    if $nightly; then
      download_loc="download/nightly"
    else
      download_loc="latest/download"
    fi
    arch=$(uname -m)
    case "$arch" in
      x86_64|arm64)
        ;;
      aarch64)
        arch="arm64"
        ;;
      *)
        echo "Unsupported architecture: $arch"
        return 1
        ;;
    esac
    echo "Downloading Neovim"
    [ -f "$imageLocation" ] && rm "$imageLocation"
    curl -Lo "$imageLocation" "https://github.com/neovim/neovim/releases/$download_loc/nvim-linux-$arch.appimage" && chmod u+x "$imageLocation"
  fi
}

getNightlyStatus() {
  if [ -f "$imageLocation" ]; then
    "$imageLocation" -v 2>/dev/null | grep -q '\-dev' && nightly=true || nightly=false
  else
    nightly=false
  fi
}

updatepvim() {
  echo "Updating pvim"
  git --git-dir="$PVIM/.git" --work-tree="$PVIM" pull

  echo "Updating the config"
  git --git-dir="$PVIM/config/.git" --work-tree="$PVIM/config" pull

  if [ "$nvim" != "nvim" ]; then
    downloadAppimage
  fi
}

dashU=false
nightly=""
appimageNeeded=false
imageLocation="$PVIM/nvim.appimage"
dashH=false
optrem=1
while getopts ':ui:snh' opts; do
  case $opts in
    u)
      dashU=true
      ;;
    i)
      imageLocation="$OPTARG"
      ;;
    s)
      nightly=false
      appimageNeeded=true
      ;;
    n)
      nightly=true
      appimageNeeded=true
      ;;
    h)
      dashH=true
      ;;
    --)
      break
      ;;
    *)
      #Don't shift options that are meant for nvim
      optrem=$((optrem+1))
      ;;
  esac
done
shift $((OPTIND-optrem))

# Determine what Neovim to use
if [ -f "$imageLocation" ]; then
  nvim="$imageLocation"
elif command -v nvim > /dev/null && ! $appimageNeeded; then
  nvim="nvim"
else
  appimageNeeded=true
  nvim="$imageLocation"
fi

if $dashH; then
  echo "Usage:
  pvim [options] [neovimOptions]  Edit a file as your would with Neovim

Options:
  --                    Pass all following arguments to Neovim

  -u                    Update pvim, config(if git), and the appimage(if in use)
  -s                    Download latest stable appimage
  -n                    Download latest nightly appimage
  -i <appimage>         specify the image path

Use \"pvim -- -h\" to see neovim help"
  exit
fi

if $dashU; then
  updatepvim
elif $appimageNeeded; then
  downloadAppimage
fi

#run Neovim with the local files
exec "$nvim" --clean -i "$PVIM/clutter/shada/state" -u "$PVIM/pvim.lua" "$@"
